# Copy this file to .env and set your local values.
# Paths can be absolute or relative to the project root.

# ── Ingestion (src/ingest.py) ─────────────────────────────────────────────
MPD_PATH=./data/mpd/data# directory containing mpd.slice.*.json files
INGEST_OUT=./processed# output directory for ingested parquets
MPD_SLICES=500# number of slices to process (max 1000)
MPD_BATCH=50# slices per in-memory batch

# ── Preprocessing (src/preprocess.py) ────────────────────────────────────
TRACKS_PATH=./processed/tracks.parquet
PREPROCESS_OUT=./processed
MIN_SEQ_LEN=5# minimum support threshold (playlists shorter than this are dropped)
VAL_RATIO=0.1# validation partition fraction
TEST_RATIO=0.1# test partition fraction
RANDOM_SEED=42# RNG seed for reproducible corpus partition

MIN_TRACKS=20# track filtering with audio features